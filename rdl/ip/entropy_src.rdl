`include "udp.rdl"

addrmap entropy_src #(
    longint ObserveFifoDepth = 32,
    longint NumAlerts = 2
){
    bus_interface_cfg = BusInterfaceCfg'{
        racl_support : false,
        direction : BusDirection::Device,
        protocol : BusProtocol::TlUl,
        hier_path : "u_reg"
    };
    signal {
        signalwidth = 0x1;
        sigtype = SigType::InterModReqRsp;
        inter_mod_struct = "entropy_src_hw_if";
        inter_mod_package = "entropy_src_pkg";
    } ENTROPY_SRC_HW_IF;

    signal {
        desc = "Signal through which entropy_src enables the noise source.entropy_src will keep this signal high as long as it expects the noise source to operate.This is *not* a flow control signal through which entropy_src would exert backpressure on the noise source; rather this signal stays high while entropy_src is enabled.";
        signalwidth = 0x1;
        sigtype = SigType::InterModReq;
        inter_mod_struct = "logic";
    } ENTROPY_SRC_RNG_ENABLE;

    signal {
        desc = "Acknowledgement signal from the noise source.When '1', it indicates that the entropy_src_rng_bit data is valid and ready to be consumed.";
        signalwidth = 0x1;
        sigtype = SigType::InterModRecv;
        inter_mod_struct = "logic";
    } ENTROPY_SRC_RNG_VALID;

    signal {
        desc = "Output data bus carrying the raw entropy bits from the noise source.These bits are valid when entropy_src_rng_valid is asserted.The width is determined by RngBusWidth parametrization.";
        signalwidth = 0x4;
        sigtype = SigType::InterModRecv;
        inter_mod_struct = "logic";
    } ENTROPY_SRC_RNG_BITS;

    signal {
        desc = "Valid signal for the external health test interface.When asserted, it indicates that entropy_src_xht_bits, entropy_src_xht_bit_sel, and entropy_src_xht_meta are valid for consumption by the external health test.";
        signalwidth = 0x1;
        sigtype = SigType::InterModReq;
        inter_mod_struct = "logic";
    } ENTROPY_SRC_XHT_VALID;

    signal {
        desc = "Carries the raw entropy data from the entropy source to be consumed by the external health test module.The data on this bus is valid when entropy_src_xht_valid is asserted.The width is determined by RngBusWidth parametrization.";
        signalwidth = 0x4;
        sigtype = SigType::InterModReq;
        inter_mod_struct = "logic";
    } ENTROPY_SRC_XHT_BITS;

    signal {
        desc = "Provides bit selection information for the raw entropy data.It specifies which specific bit or subset of bits from entropy_src_xht_bit should be used.The width is determined by RngBusBitSelWidth parametrization.";
        signalwidth = 0x2;
        sigtype = SigType::InterModReq;
        inter_mod_struct = "logic";
    } ENTROPY_SRC_XHT_BIT_SEL;

    signal {
        desc = "Provides the window size of the health in bits.";
        signalwidth = 0x12;
        sigtype = SigType::InterModReq;
        inter_mod_struct = "logic";
    } ENTROPY_SRC_XHT_HEALTH_TEST_WINDOW;

    signal {
        signalwidth = 0x1;
        sigtype = SigType::InterModReqRsp;
        inter_mod_struct = "entropy_src_xht_meta";
        inter_mod_package = "entropy_src_pkg";
    } ENTROPY_SRC_XHT_META;

    signal {
        signalwidth = 0x1;
        sigtype = SigType::InterModRecv;
        inter_mod_struct = "mubi8";
        inter_mod_package = "prim_mubi_pkg";
    } OTP_EN_ENTROPY_SRC_FW_READ;

    signal {
        signalwidth = 0x1;
        sigtype = SigType::InterModRecv;
        inter_mod_struct = "mubi8";
        inter_mod_package = "prim_mubi_pkg";
    } OTP_EN_ENTROPY_SRC_FW_OVER;

    signal {
        signalwidth = 0x1;
        sigtype = SigType::InterModReq;
        inter_mod_struct = "logic";
    } RNG_FIPS;

    signal {
        signalwidth = 0x1;
        sigtype = SigType::InterModReqRsp;
        inter_mod_struct = "tl";
        inter_mod_package = "tlul_pkg";
    } TL;

    signal {
        desc = "Asserted when entropy source bits are available for firmware for consumption via !!ENTROPY_DATA register.";
        signalwidth = 0x1;
        sigtype = SigType::Interrupt;
    } ES_ENTROPY_VALID;

    signal {
        desc = "Asserted whenever the main state machine is in the alert state, e.g., due to health tests failing and reaching the threshold value configured in !!ALERT_THRESHOLD.";
        signalwidth = 0x1;
        sigtype = SigType::Interrupt;
    } ES_HEALTH_TEST_FAILED;

    signal {
        desc = "Asserted when the observe FIFO has filled to the configured threshold level (see !!OBSERVE_FIFO_THRESH).";
        signalwidth = 0x1;
        sigtype = SigType::Interrupt;
    } ES_OBSERVE_FIFO_READY;

    signal {
        desc = "Asserted when an fatal error condition is met, e.g., upon FIFO errors, or if an illegal state machine state is reached.";
        signalwidth = 0x1;
        sigtype = SigType::Interrupt;
    } ES_FATAL_ERR;

    signal {
        desc = "This alert is triggered upon the alert health test threshold criteria not met.";
        signalwidth = 0x1;
        sigtype = SigType::Alert;
    } RECOV_ALERT;

    signal {
        desc = "This alert triggers for any condition detected in the !!ERR_CODE register,which includes FIFO errors, COUNTER errors, FSM state errors,and also when integrity failures are detected on the TL-UL bus.";
        signalwidth = 0x1;
        sigtype = SigType::Alert;
    } FATAL_ALERT;

    signal {
        signalwidth = 0x1;
        sigtype = SigType::Sync;
    } CLK_I;

    signal {
        signalwidth = 0x1;
        sigtype = SigType::Sync;
    } RST_NI;

    reg {
        desc = "Interrupt State Register";
        field {
            sw = rw;
            onwrite = woclr;
            hw = rw;
            reset = false;
            desc = "Asserted when entropy source bits are available for firmware for consumption via !!ENTROPY_DATA register.";
        } ES_ENTROPY_VALID[0:0];
        field {
            sw = rw;
            onwrite = woclr;
            hw = rw;
            reset = false;
            desc = "Asserted whenever the main state machine is in the alert state, e.g., due to health tests failing and reaching the threshold value configured in !!ALERT_THRESHOLD.";
        } ES_HEALTH_TEST_FAILED[1:1];
        field {
            sw = rw;
            onwrite = woclr;
            hw = rw;
            reset = false;
            desc = "Asserted when the observe FIFO has filled to the configured threshold level (see !!OBSERVE_FIFO_THRESH).";
        } ES_OBSERVE_FIFO_READY[2:2];
        field {
            sw = rw;
            onwrite = woclr;
            hw = rw;
            reset = false;
            desc = "Asserted when an fatal error condition is met, e.g., upon FIFO errors, or if an illegal state machine state is reached.";
        } ES_FATAL_ERR[3:3];
    } INTR_STATE @ 0x0;

    reg {
        desc = "Interrupt Enable Register";
        field {
            sw = rw;
            hw = r;
            reset = 0x0;
            desc = "Enable interrupt when !!INTR_STATE.es_entropy_valid is set.";
        } ES_ENTROPY_VALID[0:0];
        field {
            sw = rw;
            hw = r;
            reset = 0x0;
            desc = "Enable interrupt when !!INTR_STATE.es_health_test_failed is set.";
        } ES_HEALTH_TEST_FAILED[1:1];
        field {
            sw = rw;
            hw = r;
            reset = 0x0;
            desc = "Enable interrupt when !!INTR_STATE.es_observe_fifo_ready is set.";
        } ES_OBSERVE_FIFO_READY[2:2];
        field {
            sw = rw;
            hw = r;
            reset = 0x0;
            desc = "Enable interrupt when !!INTR_STATE.es_fatal_err is set.";
        } ES_FATAL_ERR[3:3];
    } INTR_ENABLE @ 0x4;

    external reg {
        desc = "Interrupt Test Register";
        field {
            sw = w;
            hw = r;
            reset = 0x0;
            swmod = true;
            desc = "Write 1 to force !!INTR_STATE.es_entropy_valid to 1.";
        } ES_ENTROPY_VALID[0:0];
        field {
            sw = w;
            hw = r;
            reset = 0x0;
            swmod = true;
            desc = "Write 1 to force !!INTR_STATE.es_health_test_failed to 1.";
        } ES_HEALTH_TEST_FAILED[1:1];
        field {
            sw = w;
            hw = r;
            reset = 0x0;
            swmod = true;
            desc = "Write 1 to force !!INTR_STATE.es_observe_fifo_ready to 1.";
        } ES_OBSERVE_FIFO_READY[2:2];
        field {
            sw = w;
            hw = r;
            reset = 0x0;
            swmod = true;
            desc = "Write 1 to force !!INTR_STATE.es_fatal_err to 1.";
        } ES_FATAL_ERR[3:3];
    } INTR_TEST @ 0x8;

    external reg {
        desc = "Alert Test Register";
        field {
            sw = w;
            hw = r;
            reset = 0x0;
            swmod = true;
            desc = "Write 1 to trigger one alert event of this kind.";
        } RECOV_ALERT[0:0];
        field {
            sw = w;
            hw = r;
            reset = 0x0;
            swmod = true;
            desc = "Write 1 to trigger one alert event of this kind.";
        } FATAL_ALERT[1:1];
    } ALERT_TEST @ 0xC;

    reg {
        desc = "Register write enable for module enable register";
        field {
            sw = rw;
            onwrite = wzc;
            hw = na;
            reset = 0x1;
            desc = "When true, the !!MODULE_ENABLE register can be modified.When false, it becomes read-only.";
        } ME_REGWEN[0:0];
    } ME_REGWEN @ 0x10;

    reg {
        desc = "Register write enable for control and threshold registers";
        field {
            sw = rw;
            onwrite = wzc;
            hw = r;
            reset = 0x1;
            desc = "When this bit true and the MODULE_ENABLE field is false,the REGWEN write enable bit read as true, and is distributed toall associated control and threshold registers.When false, these registers become read-only.";
        } SW_REGUPD[0:0];
    } SW_REGUPD @ 0x14;

    reg {
        desc = "Register write enable for all control registers";
        field {
            sw = r;
            hw = w;
            reset = 0x1;
            desc = "This read-only write enable bit will allow write access to control and threshold registers that are associated with this bit, but only when the !!MODULE_ENABLE register is set to kMultiBitBool4False and the !!SW_REGUPD write enable bit is set to true.When read as false, these registers become read-only.";
        } REGWEN[0:0];
    } REGWEN @ 0x18;

    reg {
        desc = "Module enable register";
        field {
            sw = rw;
            hw = r;
            reset = 0x9;
            desc = "Setting this field to kMultiBitBool4True will enable the ENTROPY_SRC module. Setting this field to kMultiBitBool4False will effectively reset the module.The modules of the entropy complex may only be enabled and disabled in a specific order, see Programmers Guide for details.";
            encode = MultiBitBool4;
        } MODULE_ENABLE[3:0];
    } MODULE_ENABLE @ 0x1C;

    reg {
        desc = "Configuration register";
        field {
            sw = rw;
            hw = r;
            reset = 0x9;
            desc = "Setting this field to kMultiBitBool4True selects the mode targeting FIPS/CC compliance (in short FIPS mode) with hardware conditioning enabled.The ENTROPY_SRC block will use the FIPS_WINDOW, FIPS_THRESH and FIPS_WATERMARK values of the !!HEALTH_TEST_WINDOWS, health test thresholds and watermark register, respectively.Whether the ENTROPY_SRC block is indeed running with the configuration used for FIPS/CC validation is under the control of firmware.Thus, firmware must explicitly mark the produced entropy as FIPS qualified using the !!CONF.FIPS_FLAG field.Note that the hardware conditioning can still be disabled in FIPS mode by setting both !!ENTROPY_CONTROL.ES_ROUTE and !!ENTROPY_CONTROL.ES_TYPE fields to kMultiBitBool4True.However, no entropy is being passed to the block hardware interface in this mode.Setting this field to kMultiBitBool4False selects the boot-time / bypass mode in which the hardware conditioning is bypassed.";
            encode = MultiBitBool4;
        } FIPS_ENABLE[3:0];
        field {
            sw = rw;
            hw = r;
            reset = 0x9;
            desc = "This flag indicates that the ENTROPY_SRC is setup with the configuration used for FIPS/CC validation.Setting this field to kMultiBitBool4True will set the FIPS flag for the ENTROPY_SRC block output to true.";
            encode = MultiBitBool4;
        } FIPS_FLAG[7:4];
        field {
            sw = rw;
            hw = r;
            reset = 0x9;
            desc = "Setting this field to kMultiBitBool4True sets the analog RNG into a conservative operation mode that may reduce the bit rate.In this mode, the RNG potentially outputs entropy with higher entropy per bit and with a simpler sampling mechanism.";
            encode = MultiBitBool4;
        } RNG_FIPS[11:8];
        field {
            sw = rw;
            hw = r;
            reset = 0x9;
            desc = "Setting this field to kMultiBitBool4True enables the single RNG bit mode, where only one bit is sampled per symbol.";
            encode = MultiBitBool4;
        } RNG_BIT_ENABLE[15:12];
        field {
            sw = rw;
            hw = r;
            reset = 0x9;
            desc = "This field controls the scope (either by-line or by-sum) of the health checks.If set to kMultiBitBool4True, the Adaptive Proportion and Markov Tests will accumulate all RNG input lines into a single score, and thresholds will be applied to the sum all the entropy input lines.If set to kMultiBitBool4False, the RNG input lines are all scored individually.A statistical deviation in any one input line, be it due to coincidence or failure, will force rejection of the sample, and count toward the total alert count.";
            encode = MultiBitBool4;
        } THRESHOLD_SCOPE[19:16];
        field {
            sw = rw;
            hw = r;
            reset = 0x9;
            desc = "Setting this field to kMultiBitBool4True will enable reading entropy values from the !!ENTROPY_DATA register.This function also requires that the otp_en_entropy_src_fw_read input is set to kMultiBitBool8True.";
            encode = MultiBitBool4;
        } ENTROPY_DATA_REG_ENABLE[23:20];
        field {
            sw = rw;
            hw = r;
            reset = 0x0;
            desc = "When !!CONF.RNG_BIT_ENABLE is set, this field selects which bit from the RNG bus will be processed.If the IP is parameterized for a bus width less than 256 bits, the upper, unused bits of this register are ignored.";
        } RNG_BIT_SEL[31:24];
    } CONF @ 0x20;

    reg {
        desc = "Entropy control register";
        field {
            sw = rw;
            hw = r;
            reset = 0x9;
            desc = "When this field is kMultiBitBool4False, the generated entropy will be forwarded out of this module to the hardware interface.Setting this field to kMultiBitBool4True routes the generated entropy to the !!ENTROPY_DATA register to be read by firmware.Note that for !!ENTROPY_DATA to become readable, also !!CONF.ENTROPY_DATA_REG_ENABLE needs to be set to kMultiBitBool4True.In addition, the otp_en_entropy_src_fw_read input needs to be set to kMultiBitBool8True.";
            encode = MultiBitBool4;
        } ES_ROUTE[3:0];
        field {
            sw = rw;
            hw = r;
            reset = 0x9;
            desc = "When this field is kMultiBitBool4False, the hardware conditioning inside the ENTROPY_SRC block is enabled.Setting this field to kMultiBitBool4True will bypass the hardware conditioning.For this to work, also !!ENTROPY_CONTROL.ES_ROUTE needs to be set to kMultiBitBool4True to route the unconditioned, raw entropy to the !!ENTROPY_DATA register.Alternatively, the hardware conditioning can be bypassed by setting !!CONF.FIPS_ENABLE to kMultiBitBool4False.This enables the bypass / boot-time mode.";
            encode = MultiBitBool4;
        } ES_TYPE[7:4];
    } ENTROPY_CONTROL @ 0x24;

    external reg {
        hwre = true;
        desc = "Entropy data bits";
        field {
            sw = r;
            hw = rw;
            desc = "A read of this register provides generated entropy bits to firmware.For this to work also !!CONF.ENTROPY_DATA_REG_ENABLE needs to be set to kMultiBitBool4True.In addition, the otp_en_entropy_src_fw_read input needs to be set to kMultiBitBool8True.";
        } ENTROPY_DATA[31:0];
    } ENTROPY_DATA @ 0x28;

    reg {
        desc = "Health test windows register";
        field {
            sw = rw;
            hw = r;
            reset = 0x200;
            desc = "This is the window size in samples for all health tests.This value is used when entropy is being tested in FIPS/CC compliance mode (for simplicity referred to as FIPS mode).Note that the value defined in this register applies both to single-channel and multi-channel mode (see !!ENTROPY_SRC.RNG_BIT_ENABLE).Note that the number of tested bits taken by the conditioner to produce a seed is equal to the window size x symbol size, where the symbol size is 1 in single-channel mode.The only exception is the startup seed which is produced using the bits of two subsequent windows, i.e., 2 x window size x symbol tested bits.Note that NIST SP 800-90B (Table 2) requires the adaptive proportion test to be run on 1024 or 512 samples in single-channel or multi-channel mode, respectively (see !!ENTROPY_SRC.RNG_BIT_ENABLE).The startup tests must be run on at least 1024 consecutive samples (see Section 4.3 Requirements for Health Tests of NIST SP 800-90B) and this block always uses two subsequent windows for startup health testing.The use of window sizes below 512 samples is thus not recommended as this may not comply with NIST SP 800-90B.";
        } FIPS_WINDOW[15:0];
        field {
            sw = rw;
            hw = r;
            reset = 0x180;
            desc = "This is the window size in bits for all health tests when running in bypass mode.This mode is active after reset for the first and only test run, or when this mode is programmed by firmware by setting !!CONF.FIPS_ENABLE to kMultiBitBool4False.The default value is 384 bits;Note that currently only a window size of 384 is supported and tested (this corresponds to the register default value 384).Do not use any other values, unless you know what you are doing.";
        } BYPASS_WINDOW[31:16];
    } HEALTH_TEST_WINDOWS @ 0x2C;

    external reg {
        desc = "Repetition count test thresholds register";
        field {
            sw = rw;
            hw = rw;
            reset = 0xffff;
            swmod = true;
            desc = "This is the threshold size for the repetition count health test.   This value is used in FIPS mode.   This register must be written before the module is enabled.   Writing to this register will only update the register if the   written value is less than the current value of this register.   A read from this register always reflects the current value.";
        } FIPS_THRESH[15:0];
        field {
            sw = rw;
            hw = rw;
            reset = 0xffff;
            swmod = true;
            desc = "This is the threshold size for the repetition count health test   running in bypass mode. This mode is active after reset for the   first and only test run, or when this mode is programmed by firmware.   This register must be written before the module is enabled.   Writing to this register will only update the register if the   written value is less than the current value of this register.   A read from this register always reflects the current value.";
        } BYPASS_THRESH[31:16];
    } REPCNT_THRESHOLDS @ 0x30;

    external reg {
        desc = "Repetition count symbol test thresholds register";
        field {
            sw = rw;
            hw = rw;
            reset = 0xffff;
            swmod = true;
            desc = "This is the threshold size for the repetition count symbol health test.   This value is used in FIPS mode.   This register must be written before the module is enabled.   Writing to this register will only update the register if the   written value is less than the current value of this register.   A read from this register always reflects the current value.";
        } FIPS_THRESH[15:0];
        field {
            sw = rw;
            hw = rw;
            reset = 0xffff;
            swmod = true;
            desc = "This is the threshold size for the repetition count symbol health test   running in bypass mode. This mode is active after reset for the   first and only test run, or when this mode is programmed by firmware.   This register must be written before the module is enabled.   Writing to this register will only update the register if the   written value is less than the current value of this register.   A read from this register always reflects the current value.";
        } BYPASS_THRESH[31:16];
    } REPCNTS_THRESHOLDS @ 0x34;

    external reg {
        desc = "Adaptive proportion test high thresholds register";
        field {
            sw = rw;
            hw = rw;
            reset = 0xffff;
            swmod = true;
            desc = "This is the threshold size for the adaptive proportion health test.   This value is used in FIPS mode.   This register must be written before the module is enabled.   Writing to this register will only update the register if the   written value is less than the current value of this register.   A read from this register always reflects the current value.";
        } FIPS_THRESH[15:0];
        field {
            sw = rw;
            hw = rw;
            reset = 0xffff;
            swmod = true;
            desc = "This is the threshold size for the adaptive proportion health test   running in bypass mode. This mode is active after reset for the   first and only test run, or when this mode is programmed by firmware.   This register must be written before the module is enabled.   Writing to this register will only update the register if the   written value is less than the current value of this register.   A read from this register always reflects the current value.";
        } BYPASS_THRESH[31:16];
    } ADAPTP_HI_THRESHOLDS @ 0x38;

    external reg {
        desc = "Adaptive proportion test low thresholds register";
        field {
            sw = rw;
            hw = rw;
            reset = 0x0;
            swmod = true;
            desc = "This is the threshold size for the adaptive proportion health test.   This value is used in FIPS mode.   This register must be written before the module is enabled.   Writing to this register will only update the register if the   written value is greater than the current value of this register.   A read from this register always reflects the current value.";
        } FIPS_THRESH[15:0];
        field {
            sw = rw;
            hw = rw;
            reset = 0x0;
            swmod = true;
            desc = "This is the threshold size for the adaptive proportion health test   running in bypass mode. This mode is active after reset for the   first and only test run, or when this mode is programmed by firmware.   This register must be written before the module is enabled.   Writing to this register will only update the register if the   written value is greater than the current value of this register.   A read from this register always reflects the current value.";
        } BYPASS_THRESH[31:16];
    } ADAPTP_LO_THRESHOLDS @ 0x3C;

    external reg {
        desc = "Bucket test thresholds register";
        field {
            sw = rw;
            hw = rw;
            reset = 0xffff;
            swmod = true;
            desc = "This is the threshold size for the bucket health test.   This value is used in FIPS mode.   This register must be written before the module is enabled.   Writing to this register will only update the register if the   written value is less than the current value of this register.   A read from this register always reflects the current value.";
        } FIPS_THRESH[15:0];
        field {
            sw = rw;
            hw = rw;
            reset = 0xffff;
            swmod = true;
            desc = "This is the threshold size for the bucket health test   running in bypass mode. This mode is active after reset for the   first and only test run, or when this mode is programmed by firmware.   This register must be written before the module is enabled.   Writing to this register will only update the register if the   written value is less than the current value of this register.   A read from this register always reflects the current value.";
        } BYPASS_THRESH[31:16];
    } BUCKET_THRESHOLDS @ 0x40;

    external reg {
        desc = "Markov test high thresholds register";
        field {
            sw = rw;
            hw = rw;
            reset = 0xffff;
            swmod = true;
            desc = "This is the threshold size for the Markov health test.   This value is used in FIPS mode.   This register must be written before the module is enabled.   Writing to this register will only update the register if the   written value is less than the current value of this register.   A read from this register always reflects the current value.";
        } FIPS_THRESH[15:0];
        field {
            sw = rw;
            hw = rw;
            reset = 0xffff;
            swmod = true;
            desc = "This is the threshold size for the Markov health test   running in bypass mode. This mode is active after reset for the   first and only test run, or when this mode is programmed by firmware.   This register must be written before the module is enabled.   Writing to this register will only update the register if the   written value is less than the current value of this register.   A read from this register always reflects the current value.";
        } BYPASS_THRESH[31:16];
    } MARKOV_HI_THRESHOLDS @ 0x44;

    external reg {
        desc = "Markov test low thresholds register";
        field {
            sw = rw;
            hw = rw;
            reset = 0x0;
            swmod = true;
            desc = "This is the threshold size for the Markov health test.   This value is used in FIPS mode.   This register must be written before the module is enabled.   Writing to this register will only update the register if the   written value is greater than the current value of this register.   A read from this register always reflects the current value.";
        } FIPS_THRESH[15:0];
        field {
            sw = rw;
            hw = rw;
            reset = 0x0;
            swmod = true;
            desc = "This is the threshold size for the Markov health test   running in bypass mode. This mode is active after reset for the   first and only test run, or when this mode is programmed by firmware.   This register must be written before the module is enabled.   Writing to this register will only update the register if the   written value is greater than the current value of this register.   A read from this register always reflects the current value.";
        } BYPASS_THRESH[31:16];
    } MARKOV_LO_THRESHOLDS @ 0x48;

    external reg {
        desc = "External health test high thresholds register";
        field {
            sw = rw;
            hw = rw;
            reset = 0xffff;
            swmod = true;
            desc = "This is the threshold size for the external health test.   This value is used in FIPS mode.   This register must be written before the module is enabled.   Writing to this register will only update the register if the   written value is less than the current value of this register.   A read from this register always reflects the current value.";
        } FIPS_THRESH[15:0];
        field {
            sw = rw;
            hw = rw;
            reset = 0xffff;
            swmod = true;
            desc = "This is the threshold size for the external health test   running in bypass mode. This mode is active after reset for the   first and only test run, or when this mode is programmed by firmware.   This register must be written before the module is enabled.   Writing to this register will only update the register if the   written value is less than the current value of this register.   A read from this register always reflects the current value.";
        } BYPASS_THRESH[31:16];
    } EXTHT_HI_THRESHOLDS @ 0x4C;

    external reg {
        desc = "External health test low thresholds register";
        field {
            sw = rw;
            hw = rw;
            reset = 0x0;
            swmod = true;
            desc = "This is the threshold size for the external health test.   This value is used in FIPS mode.   This register must be written before the module is enabled.   Writing to this register will only update the register if the   written value is greater than the current value of this register.   A read from this register always reflects the current value.";
        } FIPS_THRESH[15:0];
        field {
            sw = rw;
            hw = rw;
            reset = 0x0;
            swmod = true;
            desc = "This is the threshold size for the external health test   running in bypass mode. This mode is active after reset for the   first and only test run, or when this mode is programmed by firmware.   This register must be written before the module is enabled.   Writing to this register will only update the register if the   written value is greater than the current value of this register.   A read from this register always reflects the current value.";
        } BYPASS_THRESH[31:16];
    } EXTHT_LO_THRESHOLDS @ 0x50;

