    external reg {
        desc = "Repetition count test failure counter register";
        field {
            sw = r;
            hw = w;
            desc = "This register will hold a running count of test failures observed   during normal operation. It will persist until cleared.";
        } REPCNT_TOTAL_FAILS[31:0];
    } REPCNT_TOTAL_FAILS @ 0x78;

    external reg {
        desc = "Repetition count symbol test failure counter register";
        field {
            sw = r;
            hw = w;
